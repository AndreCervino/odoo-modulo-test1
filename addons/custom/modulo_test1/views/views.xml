<odoo>
    <!-- Vista lista -->
    <record id="view_tarea_list" model="ir.ui.view">
        <field name="name">modulo_test1.tarea.list</field>
        <field name="model">modulo_test1.tarea</field>
        <field name="arch" type="xml">
            <tree string="Tareas">
                <field name="name"/>
                <field name="fecha"/>
                <field name="realizada"/>
            </tree>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_tarea_form" model="ir.ui.view">
        <field name="name">modulo_test1.tarea.form</field>
        <field name="model">modulo_test1.tarea</field>
        <field name="arch" type="xml">
            <form string="Tarea">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="fecha"/>
                        <field name="realizada"/>
                    </group>
                    <field name="descripcion" placeholder="Escribe aquí la descripción..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_tarea" model="ir.actions.act_window">
        <field name="name">Tareas</field>
        <field name="res_model">modulo_test1.tarea</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_agenda_root"
              name="Agenda"
              sequence="10"/>
    <menuitem id="menu_agenda_tareas"
              name="Tareas"
              parent="menu_agenda_root"
              action="action_tarea"/>
</odoo>